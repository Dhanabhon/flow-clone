{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the FlowClone main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file",
    "shell:default"
  ]
}
