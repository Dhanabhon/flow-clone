{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowClone",
  "version": "0.1.0",
  "identifier": "app.flowclone.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlowClone - SSD Migration Assistant",
        "width": 900,
        "height": 640,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "fullscreen": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/flowimg.icns": "flowimg.icns"
    },
    "category": "Utility",
    "shortDescription": "Open-source SSD migration assistant for macOS",
    "longDescription": "FlowClone guides SSD migration workflows with mock Direct Clone and Image Migration flows in Phase 1. It is not ready for real disk operations."
  }
}
