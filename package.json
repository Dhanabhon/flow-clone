{
  "name": "flowclone",
  "private": true,
  "version": "0.3.3",
  "description": "FlowClone — Safe SSD Cloning. Tauri v2 + React + Rust.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "build": "pnpm --filter desktop build",
    "desktop": "pnpm --filter desktop tauri",
    "tauri": "pnpm --filter desktop tauri",
    "cli": "cargo run -p flowclone-cli --",
    "sidecar": "bash scripts/build-sidecar.sh",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test && cargo test --workspace"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
